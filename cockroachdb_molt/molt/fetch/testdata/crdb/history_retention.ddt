exec source
SET CLUSTER SETTING sql.history_retention_job.poll_interval = '1s'
----
[source] SET CLUSTER SETTING

# Somehow we need to pause a bit here, otherwise, fetch would fail with "table whitebear doesn't exist on source".
exec source
SELECT pg_sleep(3)
----
[source] SELECT 1

# Make a slow export
fetch drop-and-recreate-schema direct flush-rows=100 history-retention-frequency=1s shards=2
----
history retention job is extended

exec source
SELECT pg_sleep(10)
----
[source] SELECT 1

# Confirm that the PTS is gone.
check-hr-job-status
----
canceled

# Test with failed export, ensuring the the HR job is cancelled.
# The export job failed after 10s, so there should have been (10/2=) 5 extensions.
fetch drop-and-recreate-schema direct flush-rows=100 history-retention-frequency=2s shards=2 failed-conn-export=10s expect-error
----
history retention job is cancelled after 5 extensions
forced error when establishing conn for export

exec source
RESET CLUSTER SETTING jobs.registry.interval.adopt
