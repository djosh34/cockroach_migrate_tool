create-schema-stmt employees
CREATE TABLE employees (
   employee_id SERIAL PRIMARY KEY,
   employee_name VARCHAR(50) NOT NULL,
   department_id INT REFERENCES department(department_id) ON DELETE CASCADE
);
----
CREATE TABLE public.employees (employee_id INT4 NOT NULL PRIMARY KEY, employee_name VARCHAR NOT NULL, department_id INT4)

create-schema-stmt employees
CREATE TABLE employees (
   id SERIAL PRIMARY KEY,
   name VARCHAR(50) UNIQUE NOT NULL,
   age INTEGER,
   address VARCHAR(50) NOT NULL,
   start_date DATE,
   end_date DATE,
   CONSTRAINT check_dates CHECK (start_date <= end_date),  -- Check Constraint
   CONSTRAINT unique_constraint_name UNIQUE (start_date)  -- Secondary index
);
----
CREATE TABLE public.employees (id INT4 NOT NULL PRIMARY KEY, name VARCHAR NOT NULL, age INT4, address VARCHAR NOT NULL, start_date DATE, end_date DATE)

