create-schema-stmt employees
CREATE TABLE employees (
   id INT PRIMARY KEY,
   unique_id UUID NOT NULL,
   name VARCHAR(50) NOT NULL,
   created_at TIMESTAMPTZ,
   updated_at DATE,
   is_hired BOOLEAN,
   age SMALLINT CHECK (age > 18),
   salary NUMERIC(8, 2),
   bonus REAL unique
);
----
