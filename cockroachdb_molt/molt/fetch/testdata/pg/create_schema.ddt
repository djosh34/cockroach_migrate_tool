create-schema-stmt employees
CREATE TABLE employees (
   id INT NOT NULL,
   unique_id UUID NOT NULL,
   name VARCHAR(50) NOT NULL,
   created_at TIMESTAMPTZ,
   updated_at DATE,
   is_hired BOOLEAN,
   age SMALLINT CHECK (age > 18),
   salary NUMERIC(8, 2),
   bonus REAL unique,
   CONSTRAINT "primary" PRIMARY KEY (id, unique_id, created_at)
);
----
CREATE TABLE public.employees (id INT4 NOT NULL, unique_id UUID NOT NULL, name VARCHAR NOT NULL, created_at TIMESTAMPTZ NOT NULL, updated_at DATE, is_hired BOOL, age INT2, salary DECIMAL(8,2), bonus FLOAT4, CONSTRAINT "primary" PRIMARY KEY (id, unique_id, created_at))

