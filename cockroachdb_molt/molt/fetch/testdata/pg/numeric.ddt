create-schema-stmt numerictable
CREATE TABLE numerictable (
    smallintcol smallint,
    intcol integer,
    bigintcol bigint,
    decimalcol decimal,
    numericcol numeric,
    numericcol1 numeric(3,1),
    numericcol2 numeric(2,-3),
    realcol real,
    doublepreccol double precision,
    smallserialcol smallserial,
    serialcol serial,
    bigserialcol bigserial
)
----
CREATE TABLE public.numerictable (smallintcol INT2, intcol INT4, bigintcol INT8, decimalcol DECIMAL, numericcol DECIMAL, numericcol1 DECIMAL(3,1), numericcol2 DECIMAL(2), realcol FLOAT4, doublepreccol FLOAT8, smallserialcol INT2 NOT NULL, serialcol INT4 NOT NULL, bigserialcol INT8 NOT NULL)
