# Database with not mismatching regions.
exec silent
psql 'postgres://root@localhost:26257/defaultdb?sslmode=disable' -c "CREATE DATABASE newdb; ALTER DATABASE newdb SET PRIMARY REGION 'us-east-2';"
----

exec
psql 'postgres://root@localhost:26257/newdb?sslmode=disable' -c "SHOW REGIONS FROM DATABASE newdb"
----
database |  region   | primary | secondary |    zones     
----------+-----------+---------+-----------+--------------
 newdb    | us-east-2 | t       | f         | {us-east-2a}
(1 row)

exec silent
psql 'postgres://root@localhost:26257/newdb?sslmode=disable' -c "CREATE TABLE newtable (id INT PRIMARY KEY, v STRING, y INT NOT NULL) LOCALITY REGIONAL BY ROW; ALTER TABLE newtable ALTER PRIMARY KEY USING COLUMNS (id, y); INSERT INTO newtable (id, y, v, crdb_region) VALUES (1, 1, 'aa', 'us-east-2'), (2, 2, 'bb', 'us-east-2');"
----

exec silent
psql 'postgres://root@localhost:26267/defaultdb?sslmode=disable' -c "CREATE DATABASE newdb; ALTER DATABASE newdb SET PRIMARY REGION 'us-east-3';ALTER DATABASE newdb ADD REGION 'us-east-1';"
----

exec
psql 'postgres://root@localhost:26267/newdb?sslmode=disable' -c "SHOW REGIONS FROM DATABASE newdb"
----
database |  region   | primary | secondary |    zones     
----------+-----------+---------+-----------+--------------
 newdb    | us-east-3 | t       | f         | {us-east-3a}
 newdb    | us-east-1 | f       | f         | {us-east-1a}
(2 rows)

